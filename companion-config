#!/usr/bin/env bash
set -e

if [[ $(/usr/bin/id -u) -ne 0 ]]; then
    echo "Must be run as root. Try sudo companion-config"
    exit 1
fi

if [ ! -f /opt/companion/config-tool.js ]; then
    echo "The installed version of Companion does not support the configuration tool."
    echo "Update to a newer version with 'sudo companion-update' first."
    exit 1
fi

export COMPANION_CONFIG_FILE=/etc/companion/config.yaml

config_checksum() {
    md5sum "$COMPANION_CONFIG_FILE" 2>/dev/null || true
}

before=$(config_checksum)

/opt/companion/node-runtimes/main/bin/node /opt/companion/config-tool.js edit

after=$(config_checksum)

if [ "$before" == "$after" ]; then
    echo ""
    echo "No changes made."
    exit 0
fi

echo ""
if systemctl is-active --quiet companion; then
    echo "Applying changes by restarting Companion..."
    systemctl restart companion
else
    echo "Changes saved. They will apply the next time Companion starts:"
    echo "  $ sudo systemctl start companion"
fi
